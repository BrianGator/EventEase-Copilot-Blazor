@page "/register/{Id:int}"
@using EventEase_Copilot_Blazor.Models
@using EventEase_Copilot_Blazor.Services
@inject EventService EventService
@inject SessionService SessionService
@inject AttendanceService AttendanceService

<NavMenu />

<h1>Register for Event</h1>

@if (eventItem is null)
{
    <div class="alert">Event not found.</div>
    <a class="btn" href="/">Back to Events</a>
}
else if (registrationComplete)
{
    <div class="success-box">Registration complete for @eventItem.EventName.</div>
    <a class="btn" href="/attendance">View Attendance</a>
}
else
{
    <section class="detail-card">
        <h2>@eventItem.EventName</h2>
        <p><strong>Date:</strong> @eventItem.EventDate.ToString("MMMM dd, yyyy")</p>
        <p><strong>Location:</strong> @eventItem.Location</p>

        <EditForm Model="registration" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <label>Name</label>
            <InputText class="input" @bind-Value="registration.Name" />

            <label>Email</label>
            <InputText class="input" @bind-Value="registration.Email" />

            <label>Phone Number</label>
            <InputText class="input" @bind-Value="registration.ContactNumber" />

            @if (!string.IsNullOrWhiteSpace(errorMessage))
            {
                <p class="alert">@errorMessage</p>
            }

            <button class="btn success" type="submit">Submit Registration</button>
            <a class="btn" href="/">Cancel</a>
        </EditForm>
    </section>
}

<p class="author-line">Written by Brian McCarthy</p>

@code {
    [Parameter]
    public int Id { get; set; }

    private EventModel? eventItem;
    private RegistrationInfo registration = new();
    private bool registrationComplete;
    private string errorMessage = string.Empty;

    protected override void OnParametersSet()
    {
        eventItem = EventService.GetEventById(Id);
    }

    private void HandleSubmit()
    {
        errorMessage = string.Empty;

        if (eventItem is null)
        {
            errorMessage = "Event not found.";
            return;
        }

        if (string.IsNullOrWhiteSpace(registration.Name) || string.IsNullOrWhiteSpace(registration.Email) || string.IsNullOrWhiteSpace(registration.ContactNumber))
        {
            errorMessage = "Please complete all registration fields.";
            return;
        }

        if (!registration.Email.Contains('@'))
        {
            errorMessage = "Please enter a valid email address.";
            return;
        }

        SessionService.SetUser(registration.Name, registration.Email);

        AttendanceService.AddRecord(new AttendanceRecord
        {
            EventId = eventItem.Id,
            EventName = eventItem.EventName,
            AttendeeName = registration.Name,
            AttendeeEmail = registration.Email,
            RegistrationDate = DateTime.Now
        });

        registrationComplete = true;
    }
}
